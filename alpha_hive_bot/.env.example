# 复制此文件为 .env 并填写真实值
# 本地：cp .env.example .env && nano .env
# Railway/Render：在 dashboard 的 Variables 配置

# Telegram Bot Token（向 @BotFather 申请）
BOT_TOKEN=123456789:AAEhBP0av5N----your_real_token_here----

# 管理员 user_id（向 @userinfobot 发消息查），逗号分隔多个
ADMIN_USER_IDS=12345678

# SQLite 文件路径（Railway/Render 上建议挂载到 persistent volume）
DB_PATH=./subscribers.db

# 简报源（默认 gh-pages，无需改）
REPORT_BASE_URL=https://wangmingjie36-creator.github.io/alpha-hive-deploy

# 每日推送小时（PDT 0-23，默认 13 即收盘后 30 分钟 13:30）
PUSH_HOUR_PDT=13
